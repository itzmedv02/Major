# Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values.

# Optional: Add your OpenWeatherMap API Key for the Dashboard Web-Location Weather feature
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# The backend API URL (Default is localhost for development)
# Do not include the /api path here; the frontend app appends it automatically.
VITE_API_URL=http://localhost:5000
